    <string name="app_name">FortniteAssist</string>
    <string name="accessibility_service_description">FortniteAssist provides aim guidance and input assistance for players with visual impairments or motor disabilities. This service captures screen content to detect game elements and provides adaptive input assistance. All processing occurs locally on your device for privacy.</string>
    
